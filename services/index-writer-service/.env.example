# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=bsl
MYSQL_PASSWORD=bsl
MYSQL_DATABASE=bsl

# OpenSearch
OS_URL=http://localhost:9200

# Index settings
BOOKS_DOC_ALIAS=books_doc_write
BOOKS_DOC_READ_ALIAS=books_doc_read
BOOKS_DOC_INDEX_PREFIX=books_doc_v1_local
BOOKS_DOC_MAPPING=infra/opensearch/books_doc_v1.mapping.json
DELETE_EXISTING=0

# Batch / bulk
MYSQL_BATCH_SIZE=1000
OS_BULK_SIZE=1000
OS_RETRY_MAX=3
OS_RETRY_BACKOFF_SEC=1.0
OS_TIMEOUT_SEC=30
REINDEX_MAX_FAILURES=1000
REINDEX_BULK_DELAY_SEC=0

# Throttling
OS_HEALTH_CHECK_INTERVAL_SEC=10
OS_HEALTH_SLEEP_YELLOW_SEC=1
OS_HEALTH_SLEEP_RED_SEC=5

# Index refresh tuning
OS_REFRESH_INTERVAL_BULK=-1
OS_REFRESH_INTERVAL_POST=1s

# Worker
JOB_POLL_INTERVAL_SEC=2

# OS sync consumer/reconciler
OS_SYNC_ENABLED=0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
OS_SYNC_TOPIC=os.sync.material.v1
OS_SYNC_GROUP_ID=index-writer-os-sync-v1
OS_SYNC_HANDLER=index-writer-os-sync-v1
OS_SYNC_POLL_TIMEOUT_SEC=1.0
OS_SYNC_CONSUMER_BATCH_SIZE=100
OS_SYNC_RETRY_MAX=3
OS_SYNC_RETRY_BACKOFF_SEC=0.5
OS_SYNC_DLQ_ENABLED=1
OS_SYNC_DLQ_SUFFIX=.dlq
OS_SYNC_RECONCILE_ENABLED=1
OS_SYNC_RECONCILE_INTERVAL_SEC=600
OS_SYNC_RECONCILE_BATCH_SIZE=500
OS_SYNC_RECONCILE_MAX_ENQUEUE=500
OS_SYNC_RECONCILE_CHECKPOINT_NAME=material_os_sync

LOG_LEVEL=INFO
